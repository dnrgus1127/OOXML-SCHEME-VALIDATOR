{
  "name": "@ooxml/core",
  "version": "0.1.0",
  "description": "OOXML XSD schema validation engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm run generate:schemas",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm run generate:schemas && tsc --noEmit",
    "clean": "rm -rf dist src/schemas",
    "generate:schemas": "tsx ../../tools/xsd-converter/src/index.ts"
  },
  "devDependencies": {
    "fast-xml-parser": "^4.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "ooxml",
    "xlsx",
    "docx",
    "pptx",
    "xsd",
    "schema",
    "validation"
  ],
  "license": "MIT"
}
