{
  "name": "xsd-converter",
  "version": "0.1.0",
  "private": true,
  "description": "XSD to JSON schema converter for OOXML validation",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "xsd-converter": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "convert": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0",
    "glob": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "xsd",
    "json",
    "converter",
    "ooxml",
    "schema"
  ],
  "license": "MIT"
}
